# 让浏览器每次加载静态资源都向服务器校验，避免改完样式后被旧缓存卡住
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

# 阅读器 viewer 外壳同理（pdf/md），避免更新后被旧缓存卡住
/viewer-pdf.html
  Cache-Control: public, max-age=0, must-revalidate
/viewer-md.html
  Cache-Control: public, max-age=0, must-revalidate

# 大创演示 /dc：迭代频繁，改完必须立刻生效
/dc/*
  Cache-Control: public, max-age=0, must-revalidate

# Explore 实时应用：HTML 与功能脚本迭代频繁，每次进入都校验最新版
/glance
  Cache-Control: private, max-age=0, must-revalidate
/glance.html
  Cache-Control: private, max-age=0, must-revalidate
/newsnow
  Cache-Control: private, max-age=0, must-revalidate
/newsnow.html
  Cache-Control: private, max-age=0, must-revalidate

# 英汉词典分片数据：内容稳定、体积大，浏览器本地长缓存一天，避免重复下载
/dict/*
  Cache-Control: public, max-age=86400
